# ClawControl — Backend Environment
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Dashboard login password
WAGZ_PASSWORD=changeme

# JWT signing secret — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
WAGZ_SECRET_KEY=generate-a-long-random-secret-here

# OpenRouter API key (optional — ClawControl also reads this from ~/.openclaw/openclaw.json)
OPENROUTER_API_KEY=

# OpenClaw gateway connection
OPENCLAW_HOST=localhost
OPENCLAW_PORT=18789

# Alert thresholds
CREDIT_ALERT_FLOOR=5.0        # Alert when credit balance falls below this (USD)
DAILY_BURN_CEILING=10.0       # Alert when daily spend approaches this (USD)
CPU_TEMP_THRESHOLD=85         # Alert when CPU temperature exceeds this (°C)
